# Lily Chat 环境配置

# 数据库配置（使用独立的数据库）
MONGODB_URI=mongodb://localhost:27017/lily-chat

# JWT密钥 (生产环境请使用强随机密钥，至少32个字符)
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-strong-random-secret-key-change-in-production-min-32-chars

# Token 过期时间（访问令牌；默认代码内为 30d，此处可覆盖）
JWT_EXPIRES_IN=30d
TOKEN_REFRESH_EXPIRES_IN=30d

# 数据加密密钥 (用于加密身份证号等敏感信息，至少32个字符)
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-encryption-key-change-in-production-min-32-chars

# 服务器配置
PORT=8083
NODE_ENV=production

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# 日志配置
LOG_LEVEL=info

# 用户反馈列表接口（可选）：设置后 GET /api/feedback 需携带请求头 x-admin-key
# FEEDBACK_ADMIN_KEY=your-long-random-string

# 反馈邮件通知（可选，需同时配置下方 SMTP；QQ 邮箱在「设置-账户」中开启 SMTP 并使用授权码作为 SMTP_PASS）
# 多个收件人用英文逗号分隔
# FEEDBACK_NOTIFY_EMAIL=your@qq.com
# FEEDBACK_CONFIRM_EMAIL=true
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your@qq.com
# SMTP_PASS=your-smtp-authorization-code
# MAIL_FROM=Lily Chat <your@qq.com>
# 邮件里附图完整链接前缀（可选），例如 https://api.sdgsxy.cn
# PUBLIC_API_ORIGIN=https://api.sdgsxy.cn
